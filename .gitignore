# --- DreamTalk Pro Global GitIgnore ---

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints
venv/
env/
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# AI Models & Large Binary Files
# We ignore the actual weights but keep the directory structure if possible
ai_models/**/*.pth
ai_models/**/*.onnx
ai_models/**/*.t7
ai_models/**/*.bin
ai_models/**/*.pb
ai_models/**/*.weights

# Assets & Generated Content
assets/avatars/*
assets/outputs/*
!assets/avatars/.gitkeep
!assets/outputs/.gitkeep

# Build & Tooling
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts
.vercel
.turbo
.eslintcache

# Logs & Debugging
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pip-log.txt
pip-delete-this-directory.txt

# OS Specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE Specific
.vscode/
.idea/
*.swp
*.swo
.trae/
